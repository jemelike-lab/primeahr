{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/process-inbox",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/drain-outbox",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/scan-reminders",
      "schedule": "*/5 * * * *"
    }
  ]
}
